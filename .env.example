# .env.example
# Copy this file to .env and replace the placeholder values with your actual database credentials

# Admin connection used for reading schemas (sync_schema.py)
# Requires SELECT permissions on system catalogs to inspect tables and columns.
DATABASE_URL="postgresql+psycopg2://admin_user:admin_password@localhost:5432/your_db"

# Read-only connection used for securely executing generated queries (generate_sql.py)
# CRITICAL: Ensure this user only has SELECT privileges to prevent accidental data modification!
READONLY_DATABASE_URL="postgresql+psycopg2://readonly_user:readonly_password@localhost:5432/your_db"
